{
  "name": "@chenzy-design/tokens",
  "version": "0.2.0",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./uno-theme": {
      "types": "./dist/uno-theme.d.ts",
      "import": "./dist/uno-theme.js"
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx src/build.ts && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "a11y:contrast": "tsx src/contrast-check.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
