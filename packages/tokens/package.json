{
  "name": "@chenzy-design/tokens",
  "version": "0.3.1",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./uno-theme": {
      "types": "./dist/uno-theme.d.ts",
      "import": "./dist/uno-theme.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./token-manifest.json": "./dist/token-manifest.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx src/build.ts && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "a11y:contrast": "tsx src/contrast-check.ts"
  },
  "devDependencies": {
    "tsx": "^4.23.0"
  }
}
