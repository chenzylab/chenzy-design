{
  "name": "@chenzy-design/svelte",
  "version": "0.3.1",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css",
    "*.svelte"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components.json": {
      "types": "./dist/components.d.ts",
      "default": "./dist/components.json"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "svelte-package -i src -o dist && node scripts/clean-dist.mjs && pnpm build:meta",
    "build:meta": "tsx scripts/build-components-json.ts",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@chenzy-design/core": "workspace:*",
    "@chenzy-design/icons": "workspace:*",
    "@chenzy-design/locale": "workspace:*",
    "@chenzy-design/tokens": "workspace:*",
    "@douyinfe/semi-json-viewer-core": "^2.101.0",
    "@floating-ui/dom": "^1.8.0",
    "@tiptap/core": "^3.27.3",
    "@tiptap/extension-image": "^3.27.3",
    "@tiptap/extension-text-align": "^3.27.3",
    "@tiptap/extension-text-style": "^3.27.3",
    "@tiptap/extensions": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "prism-svelte": "^0.5.0",
    "prismjs": "^1.29.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "svelte-tiptap": "^3.0.1",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/hast": "^3.0.5",
    "@types/prismjs": "^1.26.5",
    "tsx": "^4.23.1"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0"
  }
}
