{
  "name": "@chenzy-design/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "meta": "pnpm --filter @chenzy-design/svelte build:meta",
    "predev": "pnpm run meta",
    "dev": "vite dev",
    "prebuild": "pnpm run meta",
    "build": "vite build && pagefind --site build",
    "search": "pagefind --site build",
    "preview": "vite preview",
    "pretypecheck": "pnpm run meta",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@chenzy-design/icons": "workspace:*",
    "@chenzy-design/icons-lab": "workspace:*",
    "@chenzy-design/svelte": "workspace:*",
    "@chenzy-design/tokens": "workspace:*",
    "@chenzy-design/unocss-preset": "workspace:*",
    "prismjs": "^1.29.0"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@unocss/preset-icons": "^66.7.2",
    "@unocss/preset-typography": "66.7.2",
    "lottie-web": "^5.13.0",
    "mdsvex": "^0.11.2",
    "pagefind": "^1.0.0",
    "shiki": "^1.29.2",
    "unocss": "^66.7.2"
  }
}
