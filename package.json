{
  "name": "chenzy-design",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:tokens": "pnpm --filter @chenzy-design/tokens build",
    "a11y:contrast": "pnpm --filter @chenzy-design/tokens a11y:contrast",
    "build": "pnpm build:tokens && pnpm -r --filter './packages/*' build",
    "dev": "pnpm --filter @chenzy-design/docs dev",
    "play": "pnpm --filter @chenzy-design/playground dev",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "test": "vitest run --project unit --project dom",
    "test:watch": "vitest",
    "test:a11y": "vitest run --project dom",
    "test:e2e": "vitest run --project browser",
    "perf:size": "size-limit",
    "perf:bench": "vitest bench --run",
    "perf:baseline": "size-limit --json > perf/baseline.json || true",
    "perf:check": "size-limit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@eslint/js": "^10.0.1",
    "@size-limit/esbuild": "^12.1.0",
    "@size-limit/file": "^12.1.0",
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.4.2",
    "@types/node": "^25.9.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "axe-core": "^4.12.1",
    "esbuild-svelte": "^0.9.5",
    "eslint": "^10.5.0",
    "jsdom": "^27.4.0",
    "playwright": "^1.61.1",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^4.1.1",
    "size-limit": "^12.1.0",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.1.1"
  },
  "pnpm": {
    "overrides": {
      "unocss": "^66.7.2"
    }
  }
}
